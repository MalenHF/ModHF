<?xml version="1.0" encoding="utf-8"?>

<configs>
	
	<append xpath="/blocks">
		<block name="eventmachine">
			<property name="ItemTypeIcon" value="star"/>
			<property name="Tags" value="noblocks"/>		
			
			<property name="CustomIcon" value="cntVendingMachine"/>

			<property name="CustomIconTint" value="cc8899"/>
			<property name="MultiBlockDim" value="1,2,1"/>
			<property name="MaxDamage" value="2000"/>
			<property name="Model" value="@:Entities/Commercial/vendingMachinePlayerPrefab.prefab"/>									
			<property name="Class" value="Workstation"/>
			<property name="Material" value="Mmetal"/>
			<property name="StabilitySupport" value="false"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="DisplayType" value="blockMulti"/>
			<property name="ImposterDontBlock" value="true"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="OnlySimpleRotations" value="true"/>
			<property name="IsTerrainDecoration" value="true"/>
			<property name="Stacknumber" value="1"/>
			<property class="Workstation">
				<property name="Modules" value="output"/>
				<property name="CraftingAreaRecipes" value="evtmachine"/>
			</property>
			<property name="WorkstationIcon" value="ui_game_symbol_workbench"/>
			<property name="OpenSound" value="open_apache_artifact_chest"/>
			<property name="CloseSound" value="close_workbench"/>
			<property name="WorkstationJournalTip" value="workbenchTip"/>
			<property class="RepairItems">
				<property name="resourceForgedIron" value="25"/>
				<property name="resourceMechanicalParts" value="20"/>
				<property name="resourceWood" value="50"/>
			</property>
			<drop event="Harvest" name="resourceScrapIron" count="200" tag="allHarvest"/>
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="terrDestroyedWoodDebris" count="1" prob="0.75" stick_chance="1"/>
			<property name="TakeDelay" value="5"/>
			<property name="DescriptionKey" value="decomachineDesc"/>
			<property name="EconomicValue" value="2000"/>
			<property name="Group" value="Building,advBuilding"/>
			<property name="FilterTags" value="fdecor,fother,ffurniture"/>
			<property name="SortOrder1" value="70i0"/>
			<property name="WorkstationWindow" value="workstation_workbench" />
		</block>

		<block name="xmasTree">			
			<property name="Class" value="GameEvent"/>
			<property name="ActivateEvent" value="test_POIReset"/>
			<!-- <property name="ActivateTime" value="60"/> -->			
			<property name="CustomIcon" value="treeJuniper4m"/>
			<property name="DescriptionKey" value="xmasTreeDesc"/>
			<property name="Tags" value="xmasEvent"/>
			<property name="Material" value="Mstone"/>
			<property name="Shape" value="New"/>
			<property name="Model" value="@:Shapes/poi_part_helper.fbx"/>
			<property name="Texture" value="8,8,539,8,537,8"/>
			<property name="DestroyOnEvent" value="false"/>

			<property name="CustomCommandName1" value="Spawn Zombie"/>
			<property name="CustomCommandIcon1" value="ui_game_symbol_zombie"/>
			<property name="CustomCommandEvent1" value="spawn_standard"/>

			<property name="CustomCommandName2" value="Spawn Vulture"/>
			<property name="CustomCommandIcon2" value="ui_game_symbol_hand"/>
			<property name="CustomCommandEvent2" value="spawn_vulture"/>
		</block>
		<block name="event_xmasTreeFloor">
            <property name="Group" value="Building,advBuilding"/>
            <property name="DescriptionKey" value="stainlessSteelBlockGroupDesc"/>
            <property name="DisplayType" value="blockHardened"/>
            <property name="StabilityFull" value="true"/>
            <!--  <property name="ImposterExchange" value="imposterBlock" param1="77"/>  -->
            <property name="CreativeMode" value="Player"/>
            <drop event="Harvest" name="resourceScrapIron" count="15" tag="allHarvest"/>
            <drop event="Destroy" count="0"/>
            <drop event="Fall" name="scrapMetalPile" count="1" prob="0.75" stick_chance="1"/>
             

            <property name="EconomicBundleSize" value="1"/>
            <property name="SellableToTrader" value="false"/>
            <property name="FilterTags" value="fbuilding,fsteel"/>

            <property name="Material" value="MbedrockHF"/>
            <property name="ItemTypeIcon" value="star"/>
            <property name="CustomIcon" value="shapeCube"/>
            <property name="CustomIconTint" value="200,200,200"/>

            <property name="CreativeMode" value="Player"/>
            <property name="BuffsWhenWalkedOn" value="hfxmasevent"/>
            <!--<property name="BuffsWhenWalkedOn" value="hfBossRoom"/>-->
            <property name="Texture" value="62"/>
            <property class="UpgradeBlock">
                <property name="ToBlock" value="woodMaster"/>
                <property name="Item" value="CD"/>
                <property name="ItemCount" value="1"/>
                <property name="UpgradeHitCount" value="1"/>
            </property>
        </block>  
			
	</append>

</configs>