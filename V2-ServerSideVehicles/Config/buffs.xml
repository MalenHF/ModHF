<!-- Flyers -->

		<buff name="vehicleWhirligigCheck" hidden="true">
			<damage_type value="heat"/>
			<stack_type value="ignore"/>			
			<effect_group>
			
			<!-- Local offset parameters attach the prefab onto the model - 0,0,0 - First expresses left to right from central origin. / Second expresses up and down from central origin. / Third expresses front to back from central origin. -->
			<!-- Local rotation parameters direct the angle of the prefab onto the model - 0,0,0 - First expresses forwards/backwards angle. / Second expresses left/right twist angle. / Third expresses left/right lean angle. -->
			
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Electrical/smallGeneratorPrefab.prefab" local_offset="0,1.3,-0.14" local_rotation="0,0,0" parent_transform="GameObject"/>				
			</effect_group>
		</buff>
		
		<buff name="vehicleSharkBlimpCheck" hidden="true">
			<damage_type value="heat"/>
			<stack_type value="ignore"/>		
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="true"  transform_path="headlight"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Lighting/lantern_02PlayerPrefab.prefab" local_offset="0,1.0,1.25" local_rotation="90,0,0" parent_transform="GameObject"/>
				<!--<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Animals/Shark/animalSharkStandard.prefab" local_offset="0,.9,0" local_rotation="0,0,0" parent_transform="GameObject"/>-->
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Vehicles/jokeblimp_Prefab.prefab" local_offset="0,0.1,-0.8" local_rotation="0,0,0" local_scale=".45,.45,.45" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="false"  parent_transform="GameObject" transform_path="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="false"  parent_transform="GameObject" transform_path="Wheel0"/>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="false"  parent_transform="GameObject" transform_path="Wheel1"/>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="false"  parent_transform="GameObject" transform_path="Wheel2"/>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="false"  parent_transform="GameObject" transform_path="Wheel3"/>
				<triggered_effect trigger="onSelfBuffStart" action="SetTransformActive" active="false"  parent_transform="GameObject" transform_path="Particles"/>
			</effect_group>
		</buff>	
		
	</append>
</configs>