				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Plants/pumpkinJackoLanternPrefab.prefab" local_offset="0,2.95,0.05" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/BanditProps/Barbedwire/barbedwire_spindle_diagonal_1mPrefab.prefab" local_offset="0,0.45,2.4" local_rotation="0,45,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Traps/ironSpikesTrap2BloodPrefab.prefab" local_offset="-.68,1.2,2.3" local_rotation="-60,90,45" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Traps/ironSpikesTrapPrefab.prefab" local_offset=".68,1.2,2.3" local_rotation="70,90,45" parent_transform="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Traps/ironSpikesTrap1BloodPrefab.prefab" local_offset="-.25,.7,2.45" local_rotation="90,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Traps/ironSpikesTrap2Prefab.prefab" local_offset=".25,.7,2.45" local_rotation="90,0,0" parent_transform="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Spear/spear_steel_Prefab.prefab" local_offset=".8,1,1.55" local_rotation="90,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Spear/spear_iron_Prefab.prefab" local_offset="-.8,1,1.55" local_rotation="90,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/ClubIron/clubIronPrefab.prefab" local_offset="1.1,0.55,-1.425" local_rotation="0,0,-90" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/ClubIron/clubIronPrefab.prefab" local_offset="-1.1,0.55,-1.425" local_rotation="0,0,90" parent_transform="M"/>
