				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/LootContainers/weapon_bags_smallPrefab.prefab" local_offset="0,.8,-1.85" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Spear/spear_steel_Prefab.prefab" local_offset=".24,.58,0.9" local_rotation="90,0,0" parent_transform="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Spear/spear_iron_Prefab.prefab" local_offset="-.24,.58,0.9" local_rotation="90,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Vehicles/Car/motorPrefab.prefab" local_offset="0,.6,0" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Axe/steelAxePrefab.prefab" local_offset=".27,1,-1.4" local_rotation="-30,0,0" parent_transform="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Axe/fireaxe_ironPrefab.prefab" local_offset="-.27,1,-1.4" local_rotation="-25,0,0" parent_transform="GameObject"/>
			</effect_group>
		</buff>

		<buff name="vehicleHellDogBikeCheck" hidden="true">
			<damage_type value="heat"/>
			<stack_type value="ignore"/>			
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Ranged/RocketLauncher/rocketlauncherPrefab.prefab" local_offset="0,-0.48,.5" local_rotation="45,0,-45" parent_transform="Forks"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/LootContainers/weapon_bags_smallPrefab.prefab" local_offset="0,.8,-1.85" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Spear/spear_steel_Prefab.prefab" local_offset=".24,.58,0.9" local_rotation="90,0,0" parent_transform="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Spear/spear_iron_Prefab.prefab" local_offset="-.24,.58,0.9" local_rotation="90,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Vehicles/Car/motorPrefab.prefab" local_offset="0,.6,0" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Axe/steelAxePrefab.prefab" local_offset=".27,1,-1.4" local_rotation="-30,0,0" parent_transform="M"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Other/Items/Weapons/Melee/Axe/fireaxe_ironPrefab.prefab" local_offset="-.27,1,-1.4" local_rotation="-25,0,0" parent_transform="GameObject"/>
			</effect_group>
		</buff>
		
		<buff name="vehicleSpiderBikeCheck" hidden="true">
			<damage_type value="heat"/>		
			<stack_type value="ignore"/>			
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/LootContainers/weapon_bags_largePrefab.prefab" local_offset="0.05,.45,-1.05" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Traps/ironSpikesTrapPrefab.prefab" local_offset="0,0.5,-0.86" local_rotation="0,0,0" parent_transform="GameObject"/>				
			
				<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" target="selfAOE" range="1.2" buff="buffInjuryKnockdown01">
					<requirement name="EntityTagCompare" target="other" tags="zombie,enemy"/>
				</triggered_effect>
			</effect_group>
		</buff>		
		
<!-- Cars, Jeeps, Trucks, and Buses -->		

		<buff name="vehicleHellHound4x4Check" hidden="true">
			<damage_type value="heat"/>
			<stack_type value="ignore"/>		
			<effect_group>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Zombies/Zombies/halfCorpsePrefab.prefab" local_offset="0,1,-2" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Zombies/Zombies/corpse2Prefab.prefab" local_offset="0,1.1,2.3" local_rotation="0,90,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/Plants/pumpkinJackoLanternPrefab.prefab" local_offset="0,2.95,0.05" local_rotation="0,0,0" parent_transform="GameObject"/>
				<triggered_effect trigger="onSelfBuffStart" action="AttachPrefabToEntity" prefab="@:Entities/BanditProps/Barbedwire/barbedwire_spindle_diagonal_1mPrefab.prefab" local_offset="0,0.45,2.4" local_rotation="0,45,0" parent_transform="GameObject"/>
			</effect_group>
		</buff>

